# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=troque-isto-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (PostgreSQL)
POSTGRES_DB=iomat
POSTGRES_USER=iomat
POSTGRES_PASSWORD=iomat
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (broker + result backend do Celery)
REDIS_URL=redis://localhost:6379/0

# Criptografia das chaves OpenAI dos usuarios (Fernet)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Superuser inicial (opcional, usado por script de seed)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
